# Copy to .env.local and fill in. Generate AUTH_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Database (Turso / libSQL).
#   - Local dev: leave BOTH empty → uses a local file at data/pm.db.
#   - Production (Vercel): create a DB at https://turso.tech, then set both.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# GitHub OAuth — callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth — redirect: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email for password reset (Resend recommended)
RESEND_API_KEY=""
EMAIL_FROM="Task Bucket <onboarding@resend.dev>"

# Or SMTP instead of Resend:
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
